{
    "name": "musicblocks",
    "version": "3.4.1",
    "main": "electron-main.js",
    "description": "A musical microworld",
    "repository": {
        "url": "https://github.com/sugarlabs/musicblocks.git"
    },
    "license": "AGPL-3.0 License",
    "bugs": {
        "url": "https://github.com/sugarlabs/musicblocks/issues"
    },
    "engines": {
        "node": "^20.0.0"
    },
    "packageManager": "pnpm@11.8.0",
    "amd": {},
    "scripts": {
        "lint": "eslint .",
        "lint:staged": "lint-staged",
        "prepare": "husky",
        "serve": "http-server -a 127.0.0.1 -p 3000 --gzip --brotli",
        "serve:dev": "http-server -a 127.0.0.1 -p 3000 -c-1",
        "start": "node index.js",
        "dev": "cross-env NODE_ENV=development nodemon index.js",
        "prod": "cross-env NODE_ENV=production node index.js",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "cypress:run": "cypress run",
        "electron": "electron .",
        "dist": "electron-builder"
    },
    "devDependencies": {
        "@babel/core": "^7.28.5",
        "@babel/eslint-parser": "^7.28.5",
        "@babel/preset-env": "^7.29.5",
        "@eslint/js": "^9.0.0",
        "cross-env": "^7.0.3",
        "cypress": "^15.15.0",
        "electron": "40.8.5",
        "electron-builder": "26.8.1",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.0.0",
        "fake-indexeddb": "6.2.5",
        "globals": "^14.0.0",
        "gulp": "^5.0.1",
        "gulp-babel": "^8.0.0",
        "gulp-clean-css": "^4.3.0",
        "gulp-prettier": "^3.0.0",
        "gulp-uglify": "^3.0.2",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.4.1",
        "lint-staged": "^15.5.2",
        "nodemon": "^3.1.9",
        "prettier": "^3.8.3"
    },
    "dependencies": {
        "@tonejs/midi": "^2.0.28",
        "abcjs": "6.3.0",
        "autoprefixer": "^10.5.0",
        "compression": "^1.8.1",
        "cssnano": "^7.1.9",
        "express": "5.2.1",
        "gulp-concat": "^2.6.1",
        "gulp-postcss": "^10.0.0",
        "gulp-replace": "^1.1.4",
        "gulp-sass": "^6.0.1",
        "gulp-sourcemaps": "^3.0.0",
        "howler": "1.1.25",
        "http-server": "^14.1.1",
        "i18next": "^25.8.18",
        "i18next-http-backend": "^3.0.5",
        "jquery": "3.7.1",
        "jquery-ui-dist": "1.12.1",
        "materialize-css": "0.100.2",
        "postcss": "^8.5.14",
        "sass": "^1.98.0",
        "tone": "^15.1.22"
    },
    "build": {
        "appId": "com.musicblocks.app",
        "productName": "Music Blocks",
        "mac": {
            "category": "public.app-category.music",
            "target": "dmg"
        },
        "win": {
            "target": "nsis"
        },
        "linux": {
            "target": "AppImage"
        }
    },
    "lint-staged": {
        "*.{js,mjs}": [
            "eslint --max-warnings=0 --fix --no-warn-ignored",
            "prettier --write"
        ]
    }
}
