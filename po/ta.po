#: js/blocks/PitchBlocks.js:765
#. AUTOTRANSLATED: Google Translate
msgid "Y to pitch block will convert a staff y position to corresponding pitch notation."
msgstr "ஒய் முதல் பிட்ச் பிளாக் என்பது பணியாளர் y நிலையை தொடர்புடைய பிட்ச் குறிப்பிற்கு மாற்றும்."


#: js/blocks/PitchBlocks.js:879
#. AUTOTRANSLATED: Google Translate
msgid "accidental selector"
msgstr "தற்செயலான தேர்வாளர்"


#: js/blocks/PitchBlocks.js:882
#. AUTOTRANSLATED: Google Translate
msgid "The Accidental selector block is used to choose between double-sharp, sharp, natural, flat, and double-flat."
msgstr "தற்செயலான தேர்வாளர் தொகுதி இரட்டை-கூர்மையான, கூர்மையான, இயற்கையான, தட்டையான மற்றும் இரட்டை-தட்டையைத் தேர்வுசெய்யப் பயன்படுகிறது."


#: js/blocks/PitchBlocks.js:898
#. AUTOTRANSLATED: Google Translate
msgid "Pitch can be specified in terms of ni dha pa ma ga re sa."
msgstr "சுருதியை நி தா ப மா கா ரீ ச அடிப்படையில் குறிப்பிடலாம்."


#: js/blocks/PitchBlocks.js:912
#. AUTOTRANSLATED: Google Translate
msgid "Pitch can be specified in terms of C D E F G A B."
msgstr "சுருதியை C D E F G A B இன் அடிப்படையில் குறிப்பிடலாம்."


#: js/blocks/PitchBlocks.js:924
#. AUTOTRANSLATED: Google Translate
msgid "solfege"
msgstr "தீர்வு"


#: js/blocks/PitchBlocks.js:927
#. AUTOTRANSLATED: Google Translate
msgid "Pitch can be specified in terms of do re mi fa sol la ti."
msgstr "சுருதியை do re mi fa sol la ti என்ற அடிப்படையில் குறிப்பிடலாம்."


#: js/blocks/PitchBlocks.js:962
#. AUTOTRANSLATED: Google Translate
msgid "The Invert block rotates any contained notes around a target note."
msgstr "தலைகீழ் தொகுதி இலக்கு குறிப்பைச் சுற்றி உள்ள எந்த குறிப்புகளையும் சுழற்றுகிறது."


#: js/blocks/PitchBlocks.js:969
#: js/widgets/modewidget.js:182
#.TRANS: pitch inversion rotates a pitch around another pitch
#. AUTOTRANSLATED: Google Translate
msgid "Invert"
msgstr "தலைகீழாக மாற்றவும்"


#: js/blocks/PitchBlocks.js:1008
#.TRANS: pitch inversion rotates a pitch around another pitch (odd number)
#. AUTOTRANSLATED: Google Translate
msgid "invert (odd)"
msgstr "தலைகீழாக (ஒற்றைப்படை)"


#: js/blocks/PitchBlocks.js:1040
#.TRANS: pitch inversion rotates a pitch around another pitch (even number)
#. AUTOTRANSLATED: Google Translate
msgid "invert (even)"
msgstr "தலைகீழாக (கூட)"


#: js/blocks/PitchBlocks.js:1061
#.TRANS: register is the octave of the current pitch
#. AUTOTRANSLATED: Google Translate
msgid "register"
msgstr "பதிவு"


#: js/blocks/PitchBlocks.js:1065
#. AUTOTRANSLATED: Google Translate
msgid "The Register block provides an easy way to modify the register (octave) of the notes that follow it."
msgstr "Register block ஆனது அதனைப் பின்பற்றும் குறிப்புகளின் பதிவேட்டை (ஆக்டேவ்) மாற்றுவதற்கான எளிதான வழியை வழங்குகிறது."


#: js/blocks/PitchBlocks.js:1088
#.TRANS: cents are units used to specify the ratio between pitches. There are 100 cents between successive notes.
#. AUTOTRANSLATED: Google Translate
msgid "50 cents"
msgstr "50 சென்ட்"


#: js/blocks/PitchBlocks.js:1119
#. AUTOTRANSLATED: Google Translate
msgid "The Semi-tone transposition block will shift the pitches contained inside Note blocks up (or down) by half steps."
msgstr "செமி-டோன் டிரான்ஸ்போசிஷன் பிளாக் குறிப்புத் தொகுதிகளுக்குள் இருக்கும் பிட்ச்களை அரை படிகள் மூலம் மேலே (அல்லது கீழ்) மாற்றும்."


#: js/blocks/PitchBlocks.js:1123
#. AUTOTRANSLATED: Google Translate
msgid "In the example shown above, sol is shifted up to sol#."
msgstr "மேலே காட்டப்பட்டுள்ள எடுத்துக்காட்டில், சோல் sol#க்கு மாற்றப்படுகிறது."


#: js/blocks/PitchBlocks.js:1129
#.TRANS: adjust the amount of shift (up or down) of a pitch
#. AUTOTRANSLATED: Google Translate
msgid "semi-tone transpose"
msgstr "அரை-தொனி இடமாற்றம்"


#: js/blocks/PitchBlocks.js:1161
#. AUTOTRANSLATED: Google Translate
msgid "The Transpose by Ratio block will shift the pitches contained inside Note blocks up (or down) by a ratio"
msgstr "டிரான்ஸ்போஸ் பை ரேஷியோ பிளாக் குறிப்புத் தொகுதிகளுக்குள் இருக்கும் பிட்ச்களை ஒரு விகிதத்தால் மேலே (அல்லது கீழ்) மாற்றும்"


#: js/blocks/PitchBlocks.js:1169
