msgstr "வகை"


#: js/blocks/ToneBlocks.js:44
#: js/widgets/timbre.js:1742
#.TRANS: Partials refers to the number of sine waves combined into the sound.
#. AUTOTRANSLATED: Google Translate
msgid "partials"
msgstr "பகுதிகள்"


#: js/blocks/ToneBlocks.js:76
#. AUTOTRANSLATED: Google Translate
msgid "You are adding multiple oscillator blocks."
msgstr "நீங்கள் பல ஆஸிலேட்டர் தொகுதிகளைச் சேர்க்கிறீர்கள்."


#: js/blocks/ToneBlocks.js:144
#: js/widgets/timbre.js:1310
#.TRANS: a duo synthesizer combines a synth with a sequencer
#. AUTOTRANSLATED: Google Translate
msgid "duo synth"
msgstr "இரட்டை சின்த்"


#: js/blocks/ToneBlocks.js:149
#. AUTOTRANSLATED: Google Translate
msgid "The Duo synth block is a duo-frequency modulator used to define a timbre."
msgstr "டியோ சின்த் பிளாக் என்பது டிம்பரை வரையறுக்கப் பயன்படும் இரட்டை அதிர்வெண் மாடுலேட்டர் ஆகும்."


#: js/blocks/ToneBlocks.js:157
#: js/widgets/timbre.js:1605
#. AUTOTRANSLATED: Google Translate
msgid "vibrato rate"
msgstr "அதிர்வு விகிதம்"


#: js/blocks/ToneBlocks.js:157
#. AUTOTRANSLATED: Google Translate
msgid "vibrato intensity"
msgstr "அதிர்வு தீவிரம்"


#: js/blocks/ToneBlocks.js:185
#: js/widgets/timbre.js:1294
#.TRANS: AM (amplitude modulation) synthesizer
#. AUTOTRANSLATED: Google Translate
msgid "AM synth"
msgstr "AM சின்த்"


#: js/blocks/ToneBlocks.js:189
#. AUTOTRANSLATED: Google Translate
msgid "The AM synth block is an amplitude modulator used to define a timbre."
msgstr "AM சின்த் பிளாக் என்பது ஒரு டிம்பரை வரையறுக்கப் பயன்படும் அலைவீச்சு மாடுலேட்டர் ஆகும்."


#: js/blocks/ToneBlocks.js:224
#: js/widgets/timbre.js:1302
#.TRANS: FM (frequency modulation) synthesizer
#. AUTOTRANSLATED: Google Translate
msgid "FM synth"
msgstr "FM சின்த்"


#: js/blocks/ToneBlocks.js:228
#. AUTOTRANSLATED: Google Translate
msgid "The FM synth block is a frequency modulator used to define a timbre."
msgstr "எஃப்எம் சின்த் பிளாக் என்பது டிம்பரை வரையறுக்கப் பயன்படும் அதிர்வெண் மாடுலேட்டர் ஆகும்."


#: js/blocks/ToneBlocks.js:262
#. AUTOTRANSLATED: Google Translate
msgid "partial"
msgstr "பகுதி"


#: js/blocks/ToneBlocks.js:265
#. AUTOTRANSLATED: Google Translate
msgid "The Partial block is used to specify a weight for a specific partial harmonic."
msgstr "ஒரு குறிப்பிட்ட பகுதி ஹார்மோனிக்கிற்கான எடையைக் குறிப்பிட பகுதித் தொகுதி பயன்படுத்தப்படுகிறது."


#: js/blocks/ToneBlocks.js:284
#.TRANS: partials are weighted components in a harmonic series
#. AUTOTRANSLATED: Google Translate
msgid "Partial weight must be between 0 and 1."
msgstr "பகுதி எடை 0 மற்றும் 1 க்கு இடையில் இருக்க வேண்டும்."


#: js/blocks/ToneBlocks.js:297
#.TRANS: partials are weighted components in a harmonic series
#. AUTOTRANSLATED: Google Translate
msgid "Partial block should be used inside of a Weighted-partials block."
msgstr "பகுதித் தொகுதியானது எடையுள்ள பகுதிகள் தொகுதியின் உள்ளே பயன்படுத்தப்பட வேண்டும்."


#: js/blocks/ToneBlocks.js:317
#. AUTOTRANSLATED: Google Translate
msgid "The Weighted partials block is used to specify the partials associated with a timbre."
msgstr "எடையுள்ள பகுதிகள் தொகுதியானது டிம்பருடன் தொடர்புடைய பகுதிகளைக் குறிப்பிடப் பயன்படுகிறது."


#: js/blocks/ToneBlocks.js:325
#.TRANS: partials are weighted components in a harmonic series
#. AUTOTRANSLATED: Google Translate
msgid "weighted partials"
msgstr "எடையுள்ள பகுதிகள்"


#: js/blocks/ToneBlocks.js:382
#. AUTOTRANSLATED: Google Translate
msgid "The Harmonic block will add harmonics to the contained notes."
msgstr "ஹார்மோனிக் தொகுதி அடங்கிய குறிப்புகளுக்கு ஹார்மோனிக்ஸ் சேர்க்கும்."


#: js/blocks/ToneBlocks.js:389
#.TRANS: A harmonic is an overtone.
#. AUTOTRANSLATED: Google Translate
msgid "harmonic"
msgstr "இசைவான"


#: js/blocks/ToneBlocks.js:430
#. AUTOTRANSLATED: Google Translate
msgid "The Distortion block adds distortion to the pitch."
msgstr "விலகல் தொகுதி சுருதிக்கு சிதைவை சேர்க்கிறது."


#: js/blocks/ToneBlocks.js:437
#.TRANS: distortion is an alteration in the sound
#. AUTOTRANSLATED: Google Translate
msgid "distortion"
msgstr "திரித்தல்"


#: js/blocks/ToneBlocks.js:486
#. AUTOTRANSLATED: Google Translate
msgid "The Tremolo block adds a wavering effect."
msgstr "ட்ரெமோலோ பிளாக் ஒரு அலைச்சல் விளைவை சேர்க்கிறது."


#: js/blocks/ToneBlocks.js:488
#. AUTOTRANSLATED: Google Translate
msgid "Tremolo makes the sound pulse louder and quieter."
msgstr "ட்ரெமோலோ ஒலி துடிப்பை சத்தமாகவும் அமைதியாகவும் செய்கிறது."


#: js/blocks/ToneBlocks.js:490
#. AUTOTRANSLATED: Google Translate
msgid "The rate (first argument) controls how fast the sound pulses (cycles per second)."
msgstr "விகிதம் (முதல் வாதம்) ஒலி துடிப்புகளை (வினாடிக்கு சுழற்சிகள்) எவ்வளவு வேகமாக கட்டுப்படுத்துகிறது."


#: js/blocks/ToneBlocks.js:494
#. AUTOTRANSLATED: Google Translate
msgid "The depth (second argument) controls the strength of the pulsing effect (0-100%)."
msgstr "ஆழம் (இரண்டாவது வாதம்) துடிப்பு விளைவின் வலிமையைக் கட்டுப்படுத்துகிறது (0-100%)."


#: js/blocks/ToneBlocks.js:504
#.TRANS: a wavering effect in a musical tone
#. AUTOTRANSLATED: Google Translate
msgid "tremolo"
msgstr "நடுக்கம்"


#: js/blocks/ToneBlocks.js:509
#: js/blocks/ToneBlocks.js:578
#: js/blocks/ToneBlocks.js:649
#: js/blocks/ToneBlocks.js:716
#: js/widgets/timbre.js:2435
#: js/widgets/timbre.js:2507
#: js/widgets/timbre.js:2587
#: js/widgets/timbre.js:2680
#.TRANS: rate at which tremolo wavers
#. AUTOTRANSLATED: Google Translate
msgid "rate"
msgstr "விகிதம்"


#: js/blocks/ToneBlocks.js:511
#: js/blocks/ToneBlocks.js:649
#: js/widgets/timbre.js:2438
#: js/widgets/timbre.js:2597
#.TRANS: amplitude of tremolo waver
#. AUTOTRANSLATED: Google Translate
msgid "depth"
msgstr "ஆழம்"


#: js/blocks/ToneBlocks.js:568
#. AUTOTRANSLATED: Google Translate
msgid "The Phaser block adds a sweeping sound."
msgstr "பேஸர் பிளாக் ஒரு பெரிய ஒலியை சேர்க்கிறது."


#: js/blocks/ToneBlocks.js:575
#.TRANS: alter the phase of the sound
#. AUTOTRANSLATED: Google Translate
msgid "phaser"
msgstr "பேஸர்"


#: js/blocks/ToneBlocks.js:578
#: js/turtleactions/IntervalsActions.js:154
#: js/widgets/timbre.js:2683
#. AUTOTRANSLATED: Google Translate
msgid "octaves"
msgstr "எண்மங்கள்"


#: js/blocks/ToneBlocks.js:578
#: js/widgets/timbre.js:2686
#. AUTOTRANSLATED: Google Translate
msgid "base frequency"
msgstr "அடிப்படை அதிர்வெண்"


#: js/blocks/ToneBlocks.js:628
#. AUTOTRANSLATED: Google Translate
msgid "The Chorus block adds a chorus effect."
msgstr "கோரஸ் தொகுதி ஒரு கோரஸ் விளைவை சேர்க்கிறது."


#: js/blocks/ToneBlocks.js:630
#. AUTOTRANSLATED: Google Translate
msgid "The rate (first argument) controls the speed of the chorus modulation (cycles per second)."
msgstr "விகிதம் (முதல் வாதம்) கோரஸ் பண்பேற்றத்தின் வேகத்தைக் கட்டுப்படுத்துகிறது (வினாடிக்கு சுழற்சிகள்)."


#: js/blocks/ToneBlocks.js:634
#. AUTOTRANSLATED: Google Translate
msgid "The delay (second argument) sets the time delay between chorus voices (milliseconds)."
msgstr "தாமதம் (இரண்டாவது வாதம்) கோரஸ் குரல்களுக்கு (மில்லி விநாடிகள்) இடையே நேர தாமதத்தை அமைக்கிறது."


#: js/blocks/ToneBlocks.js:638
#. AUTOTRANSLATED: Google Translate
msgid "The depth (third argument) controls the amount of chorus effect (0-100%)."
