msgstr ""
"<h2>ペンブロック</h2><br>ネズミが えがく せんのいろを かえる。 いろは がめんじょうで えらぶ ほか、 それぞれ すうちで きめることも"
" できる。 いろは、 0いじょうで、 100より ちいさい あたいになる。"

#. TRANS: rhythm block
#. TRANS: translate "rhythm1" as rhythm
#: js/blocks/RhythmBlockPaletteBlocks.js:63
#: js/blocks/RhythmBlockPaletteBlocks.js:242
msgid "rhythm1"
msgstr "れんぷ（かけ算）"

#: js/blocks/RhythmBlockPaletteBlocks.js:83
#: js/blocks/RhythmBlockPaletteBlocks.js:261
#: js/blocks/RhythmBlockPaletteBlocks.js:526
#: js/blocks/RhythmBlockPaletteBlocks.js:594
#: js/blocks/RhythmBlockPaletteBlocks.js:897
msgid "number of notes"
msgstr "おんぷの かず"

#: js/blocks/RhythmBlockPaletteBlocks.js:144
msgid "polyphonic rhythm"
msgstr "ポリリズム"

#: js/blocks/RhythmBlockPaletteBlocks.js:228
msgid "The Rhythm block is used to generate rhythm patterns."
msgstr ""
"<h2>れんぷブロック（かけざん）</h2><br>まとまった いくつかの おんぷ。 いっていの ながさの おとを  ３つや ５つなど くりかえして "
"つかう。３れんぷ や ５れんぷ など、 ２のばいすう ではない おんぷの かずで グループを つくりやすくなる。"

#. TRANS: Do not modify the following line
#: js/blocks/RhythmBlockPaletteBlocks.js:290
#: js/blocks/RhythmBlockPaletteBlocks.js:295
msgid "1/64 note"
msgstr "６４ぶん おんぷ"

#. TRANS: Do not modify the following line
#: js/blocks/RhythmBlockPaletteBlocks.js:321
#: js/blocks/RhythmBlockPaletteBlocks.js:326
msgid "1/32 note"
msgstr "３２ぶん おんぷ"

#. TRANS: Do not modify the following line
#: js/blocks/RhythmBlockPaletteBlocks.js:355
#: js/blocks/RhythmBlockPaletteBlocks.js:360
msgid "1/16 note"
msgstr "１６ぶん おんぷ"

#. TRANS: Do not modify the following line
#: js/blocks/RhythmBlockPaletteBlocks.js:389
msgid "eighth note"
msgstr "８ぶん おんぷ"

#. TRANS: Do not modify the following line
#: js/blocks/RhythmBlockPaletteBlocks.js:417
msgid "quarter note"
msgstr "４ぶ おんぷ"

#. TRANS: Do not modify the following line
#: js/blocks/RhythmBlockPaletteBlocks.js:445
#: js/blocks/RhythmBlockPaletteBlocks.js:450
