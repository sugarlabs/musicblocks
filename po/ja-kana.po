msgstr "ぐれーせっていぶろっくはぺんのいろのせんやかさをへんこうします。"

#: js/blocks/PenBlocks.js:1169
msgid "set color"
msgstr "いろを せってい"

#: js/blocks/PenBlocks.js:1179
